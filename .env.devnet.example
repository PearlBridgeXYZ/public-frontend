# DevNet build template.
# Copy to `.env.devnet` and point the URLs at your local Hardhat node.
# `npm run dev -- --mode devnet` or `npm run build -- --mode devnet`.
VITE_NETWORK=devnet
VITE_DEVNET_RPC_URL=http://localhost:8545
VITE_RELAY_API_BASE=http://localhost:3000
VITE_RELAY_URL=http://localhost:3000
VITE_PEARL_LOCK_ADDRESS=
VITE_MINT_FEE_BPS=50
VITE_BURN_FEE_BPS=50
VITE_WALLETCONNECT_PROJECT_ID=
